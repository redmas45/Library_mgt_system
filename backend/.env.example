# ==========================================
# Library AI System — Environment Variables
# ==========================================

# --- Application ---
APP_NAME=Library AI System
APP_VERSION=1.0.0
DEBUG=true

# --- Database ---
DATABASE_URL=sqlite:///../data/library.db

# --- JWT Auth ---
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- OpenAI / LLM Provider ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_BASE_URL=

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Vector Store ---
VECTOR_STORE_PATH=../data/embeddings/faiss_index

# --- File Storage ---
BOOKS_STORAGE_PATH=../data/books
PROCESSED_STORAGE_PATH=../data/processed

# --- Ingestion ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# --- Rate Limiting ---
RATE_LIMIT=100/minute
